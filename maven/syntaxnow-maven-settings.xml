<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              https://maven.apache.org/xsd/settings-1.0.0.xsd">

    <!-- Auth will be injected via env vars -->
    <servers>
        <server>
            <id>syntaxnow-github</id>
            <username>${env.GITHUB_ACTOR}</username>
            <password>${env.GITHUB_TOKEN}</password>
        </server>
<!--        <server>-->
<!--            <id>syntaxnow-starter-parent</id>-->
<!--            <username>${env.GITHUB_ACTOR}</username>-->
<!--            <password>${env.GITHUB_TOKEN}</password>-->
<!--        </server>-->
<!--        <server>-->
<!--            <id>syntaxnow-sso-starter</id>-->
<!--            <username>${env.GITHUB_ACTOR}</username>-->
<!--            <password>${env.GITHUB_TOKEN}</password>-->
<!--        </server>-->
    </servers>
    <!-- SyntaxNow Internal Maven Repos -->
    <profiles>
        <profile>
            <id>syntaxnow-internal</id>
            <repositories>
                <repository>
                    <id>syntaxnow-github</id>
                    <url>https://maven.pkg.github.com/SyntaxNow-Labs/syntaxnow-starter-parent</url>
                </repository>
                <repository>
                    <id>syntaxnow-github</id>
                    <url>https://maven.pkg.github.com/SyntaxNow-Labs/syntaxnow-sso-starter</url>
                </repository>
            </repositories>

        </profile>
    </profiles>
    <activeProfiles>
        <activeProfile>syntaxnow-internal</activeProfile>
    </activeProfiles>
</settings>
